# ── Backend URL ───────────────────────────────────────────────────────────────
#
# IMPORTANT — macOS / IPv4 vs IPv6 note:
#   Modern macOS resolves "localhost" to IPv6 (::1) in the browser but the
#   backend binds to IPv4 (127.0.0.1). This causes "Failed to fetch" errors.
#
#   Use http://127.0.0.1:5001  (IPv4 explicit) NOT http://localhost:5001
#
# Dev default (backend running locally via run.py):
VITE_BACKEND_URL=http://localhost:5000

# Docker Compose (backend container exposed on host port 5000):
# VITE_BACKEND_URL=http://localhost:5000

# ── Bridge URL (optional override) ────────────────────────────────────────────
# The bridge client (/design/render-route, /components/*) reads VITE_BRIDGE_URL
# first, then falls back to VITE_BACKEND_URL. Leave unset to use the same
# backend URL for both.
#
# VITE_BRIDGE_URL=http://127.0.0.1:5001

# ── Razorpay (public key only — secret stays on backend!) ─────────────────────
# Test: rzp_test_...   |   Live: rzp_live_...
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# ── Auth ──────────────────────────────────────────────────────────────────────
# Google Client ID for OAuth login (e.g. your-client-id.apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
