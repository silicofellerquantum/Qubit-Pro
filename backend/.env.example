# ── Database ──────────────────────────────────────────────────────────────────
# Dev (zero-setup SQLite — no Postgres required):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
SYNC_DATABASE_URL=sqlite:///./dev.db

# Production (Postgres):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/quantum_studio
# SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/quantum_studio

# ── Redis (optional — needed for task queues in production only) ──────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Anthropic Claude (optional — rule-based fallback if empty) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
MAX_QUBITS=256

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Demo Mode / Quick Admin Login ─────────────────────────────────────────────
# Predefined defaults exist in config.py. Left here for optional custom overrides.
DEMO_MODE=true
DEMO_ADMIN_EMAIL=admin@silicofeller.dev
DEMO_ADMIN_PASSWORD=AdminDev123!
